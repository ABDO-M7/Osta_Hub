generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  ESSAY
}

model User {
  id               Int              @id @default(autoincrement())
  email            String           @unique
  password         String?
  name             String
  role             Role             @default(STUDENT)
  // OAuth
  provider         String? // "google" | "github"
  providerId       String?
  avatar           String?
  // Profile completion
  username         String?          @unique
  phone            String?
  level            String?
  specialization   String?
  profileComplete  Boolean          @default(false)
  // Email verification
  emailVerified    Boolean          @default(false)
  emailVerifyToken String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  // Learning Progress & Streaks
  currentStreak    Int              @default(0)
  longestStreak    Int              @default(0)
  lastActivityDate DateTime?
  attempts         Attempt[]
  enrollments      Enrollment[]
  feedbacks        Feedback[]
  lessonProgresses LessonProgress[]
  notes            Note[]

  @@map("users")
}

model Subject {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  tracks      String[]     @default([]) // e.g. ["Machine Learning", "Tech"]
  order       Int          @default(0)  // for admin manual sorting
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lessons     Lesson[]
  exams       Exam[]
  enrollments Enrollment[]

  @@map("subjects")
}

model Lesson {
  id         Int              @id @default(autoincrement())
  title      String
  subjectId  Int
  order      Int              @default(0)
  topics     String[]         @default([]) // Key concepts this lesson covers
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  subject    Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  blocks     LessonBlock[]
  progresses LessonProgress[]
  notes      Note[]

  @@map("lessons")
}

model LessonBlock {
  id       Int    @id @default(autoincrement())
  lessonId Int
  type     String // paragraph, image, interactive-graph, quiz
  content  Json
  order    Int    @default(0)
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_blocks")
}

model Exam {
  id        Int        @id @default(autoincrement())
  title     String
  subjectId Int
  duration  Int // in minutes
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  Attempt[]

  @@map("exams")
}

model Question {
  id            Int          @id @default(autoincrement())
  examId        Int
  type          QuestionType
  text          String
  options       Json? // For MCQ: ["A", "B", "C", "D"]
  correctAnswer String? // For MCQ/TF
  points        Int          @default(1)
  order         Int          @default(0)
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers       Answer[]

  @@map("questions")
}

model Attempt {
  id          Int       @id @default(autoincrement())
  examId      Int
  userId      Int
  score       Float?
  totalPoints Int?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  aiAnalysis  String?   @db.Text
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     Answer[]

  @@map("attempts")
}

model Answer {
  id         Int      @id @default(autoincrement())
  attemptId  Int
  questionId Int
  response   String?
  isCorrect  Boolean?
  aiScore    Float?
  aiFeedback String?
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  userId    Int
  subjectId Int
  progress  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@map("enrollments")
}

model Feedback {
  id        Int      @id @default(autoincrement())
  userId    Int?
  message   String
  rating    Int
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("feedbacks")
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model LessonProgress {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("notes")
}
